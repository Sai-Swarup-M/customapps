# Copy to .env.local and fill in real values. Never commit .env.local

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — get from your project dashboard at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upload API key — generate any random string, e.g: openssl rand -hex 32
UPLOAD_API_KEY=your-random-secret
NEXT_PUBLIC_UPLOAD_API_KEY=your-random-secret   # same value, exposed to client for PWA upload form

# Cron protection — generate any random string
CRON_SECRET=your-random-cron-secret

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BL...
VAPID_PRIVATE_KEY=...
